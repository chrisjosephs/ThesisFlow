# =============================================================================
# ThesisFlow — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL — superuser (Docker init only, not used by the app at runtime)
# -----------------------------------------------------------------------------
POSTGRES_DB=thesisflow
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change_me_superuser
POSTGRES_PORT=5432


# -----------------------------------------------------------------------------
# PostgreSQL — application roles
# -----------------------------------------------------------------------------

# Migrator: runs DDL migrations (ALTER TABLE, CREATE INDEX, etc.)
THESISFLOW_MIGRATOR_PASSWORD=change_me_migrator

# App: runtime DML only (SELECT / INSERT / UPDATE / DELETE)
THESISFLOW_APP_PASSWORD=change_me_app

# Readonly: SELECT only — analytics, debugging, future reporting
THESISFLOW_READONLY_PASSWORD=change_me_readonly


# -----------------------------------------------------------------------------
# Connection strings (used by NestJS engine)
# -----------------------------------------------------------------------------
DATABASE_URL_MIGRATOR=postgresql://thesisflow_migrator:change_me_migrator@localhost:5432/thesisflow
DATABASE_URL_APP=postgresql://thesisflow_app:change_me_app@localhost:5432/thesisflow


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis
REDIS_PORT=6379
REDIS_URL=redis://:change_me_redis@localhost:6379


# -----------------------------------------------------------------------------
# pgAdmin  (docker compose --profile tools up)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@thesisflow.local
PGADMIN_PASSWORD=change_me_pgadmin
PGADMIN_PORT=5050


# -----------------------------------------------------------------------------
# Backups (database/backup.ps1)
# -----------------------------------------------------------------------------
# S3-compatible bucket URL — works with AWS S3, Backblaze B2, Cloudflare R2
# Leave blank to skip cloud upload and keep local backups only.
BACKUP_BUCKET=
